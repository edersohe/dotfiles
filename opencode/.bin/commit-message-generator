#!/usr/bin/env bash

CHANGES=$(git diff --cached --name-status)

if [ -z "$CHANGES" ]; then
  echo "No changes staged for commit."
  exit 1
fi

git diff --cached | opencode run "You are a specialized commit message generator. Input: Git Diff. Output: Conventional Commit formatted message only. No explanations." --model "github-copilot/gpt-5-mini" 2>/dev/null
