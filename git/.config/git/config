[user]
	name = Eder Sosa
	email = eder.sohe@gmail.com
[diff]
	algorithm = histogram
	tool = nvimdiff
[merge]
	conflictstyle = zdiff3
	tool = fugitive
[gpg]
	program = gpg
[init]
	defaultBranch = main
	templatedir = /home/eder/.config/git/template
[push]
	default = simple
	autoSetupRemote = true
	followTags = true
[tag]
	sort = version:refname
[alias]
	l = log --oneline --graph --all
	fugitive = "!f() { $EDITOR -c G -c only \"$@\"; }; f"
[core]
	editor = nvim
[mergetool "fugitive"]
	cmd = $EDITOR -c "Gvdiffsplit!" "$MERGED"
[mergetool]
	prompt = false
[difftool "nvimdiff"]
	cmd = $EDITOR -d "$LOCAL" "$REMOTE"
